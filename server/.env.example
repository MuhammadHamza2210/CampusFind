# ---- Core ----
PORT=5000
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_string

# ---- Database (optional — falls back to local Mongo) ----
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/campusfind

# ---- Auth policy ----
# Comma-separated list; each entry also matches its subdomains.
ALLOWED_EMAIL_DOMAIN=bahria.edu.pk
COOKIE_SECURE=false
ADMIN_EMAILS=

# ---- Cloudinary (optional — falls back to local disk /uploads) ----
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ---- Email / OTP ----
# Preferred: Brevo transactional email over HTTPS. Works on hosts that block
# outbound SMTP (e.g. Hugging Face). BREVO_FROM_EMAIL must be a verified sender.
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=
# BREVO_FROM_NAME=CampusFind

# Fallback: SMTP (used only if BREVO_API_KEY is unset). If this is unset too,
# OTP codes are printed to the server console for local testing.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="CampusFind <no-reply@campusfind.app>"
